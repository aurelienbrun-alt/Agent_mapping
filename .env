# ============================================================
# Enterprise regulatory framework mapper - Azure OpenAI edition
# ============================================================

DRY_RUN_WITHOUT_LLM=false

# Azure OpenAI endpoint must be the resource endpoint only, for example:
# https://my-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-01

# Recommended economical setup
AZURE_OPENAI_TEXT_DEPLOYMENT=gpt-5.4-nano
AZURE_OPENAI_CATEGORY_DEPLOYMENT=gpt-5.4-nano
AZURE_OPENAI_JUDGE_DEPLOYMENT=gpt-5.4-mini
# Final judge model — leave empty to reuse the judge model, or set a STRONGER deployment here (not used for the pairwise match)
AZURE_OPENAI_FINAL_JUDGE_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_EMBEDDING_DIMENSIONS=512
AZURE_OPENAI_TEMPERATURE=0

# Cost estimation. The run prints a per-model token cost at the end. Prices below
# are INDICATIVE placeholders (USD per 1,000,000 tokens) — replace with your real
# Azure contract rates. Uncomment and edit to override the defaults in src/cost.py.
# A deployment matches the longest key that is a substring of its name.
# MODEL_PRICING_JSON={"gpt-5.4-nano":{"input":0.10,"output":0.40},"gpt-5.4-mini":{"input":0.25,"output":2.00},"gpt-5.4":{"input":1.25,"output":10.00},"text-embedding-3-large":{"input":0.13,"output":0.0}}

# ============================================================
# Input frameworks
# ============================================================
FRAMEWORK_A_NAME=_Cyfun_2025
FRAMEWORK_A_FILE=data/Test2_Belgique.xlsx
A_SHEET_NAME=
A_ID_COLUMN=ID
A_TITLE_COLUMN=Title
A_REQUIREMENT_COLUMN=Requirement
A_CATEGORY_COLUMN=Category
A_ESSENTIAL_COLUMN=Essential
A_IMPORTANT_COLUMN=Important

FRAMEWORK_B_NAME=France_2.3
FRAMEWORK_B_FILE=data/Framework_2_France.xlsx
B_SHEET_NAME=
B_ID_COLUMN=ID
B_TITLE_COLUMN=Title
B_REQUIREMENT_COLUMN=Requirement
B_CATEGORY_COLUMN=Category
B_ESSENTIAL_COLUMN=Essential
B_IMPORTANT_COLUMN=Important

MAX_REQUIREMENTS_PER_FRAMEWORK=0

# ============================================================
# Entity criticality (NIS2 essential / important entities)
# When true, the inputs must contain the Essential and Important columns
# (True/False; Essential is always True). The final output gains Essential and
# Important columns, and a residual gap is raised (with High review priority)
# when a source requirement applicable to important entities (Important=True) is
# covered by at least one target requirement that is not (Important=False).
# NOTE: changing input columns does not invalidate the file-name cache — set
# REBUILD_CACHE=true once after adding the columns.
# ============================================================
ENABLE_ENTITY_CRITICALITY=false

# ============================================================
# Action plan (final output column)
# When true, an "Action plan" column is added to the parent output. For each
# requirement that has a material gap, an LLM turns the Gap column into 1..N
# concise remediation bullet points (the key actions to close the most important
# gaps). Fully covered requirements get no plan. Decisions are cached.
# ============================================================
ENABLE_ACTION_PLAN=true
ACTION_PLAN_BATCH_SIZE=20
ACTION_PLAN_MAX_BULLETS=4
ENABLE_ACTION_PLAN_CACHE=true
ACTION_PLAN_CACHE_FILE=action_plan_cache.jsonl
PROMPT_ACTION_PLAN="You are a cybersecurity regulatory remediation expert.\n\nFor each item below, write a concise ACTION PLAN: the key actions an organization must take to close the most important residual gaps described in the gap text.\n\nRules:\n1. Return between 1 and {max_bullets} bullet points. Never exceed {max_bullets}.\n2. Prioritize the most material gaps first; omit minor or cosmetic points.\n3. Each action must be specific, imperative and operational (what to do), max 25 words.\n4. Do not restate the requirement or the gap; state the action to remediate it.\n5. If the gap text indicates full coverage or contains no material gap, return an empty list.\n6. Do not mention scores, mappings, atoms, prompts or any technical internals.\n7. Write every action in {output_language}.\n\nReturn JSON only:\n{\"results\": [{\"id\": \"<id>\", \"actions\": [\"action 1\", \"action 2\"]}]}\n\nItems:\n{items_json}"

# ============================================================
# ENISA category harmonization and safe category repair
# ============================================================
ENABLE_CATEGORY_HARMONIZATION=true
ENISA_CATEGORY_FILE=data/enisa_categories.xlsx
ENISA_CATEGORY_SHEET=Catégories ENISA
CATEGORY_OVERRIDES_FILE=config/category_overrides.xlsx
CATEGORY_HARMONIZATION_USE_LLM=true
CATEGORY_HARMONIZATION_FORCE=false
CATEGORY_HARMONIZATION_CACHE_FILE=category_harmonization.json

# Repair existing docs/cache/*/atomic_requirements.json without re-running atomization, fields or embeddings.
# Set true only when you want to refresh category metadata in existing caches.
REPAIR_CACHE_CATEGORIES=false
REPAIR_ONLY_LOW_CONFIDENCE_CATEGORIES=false
CATEGORY_REPORT_ENABLED=true

# Category confidence policy. Categories are advisory by default; weak categories trigger global fallback.
CATEGORY_STRONG_CONFIDENCE_THRESHOLD=0.85
CATEGORY_MEDIUM_CONFIDENCE_THRESHOLD=0.60
CATEGORY_AMBIGUITY_MARGIN=0.15
ENABLE_SECONDARY_CATEGORY_MATCHING=true
MAX_SECONDARY_CATEGORIES=2

# Recommended default: category is a boost, never a hard filter.
MATCH_SCOPE=soft_enisa
CATEGORY_CASE_SENSITIVE=false
CATEGORY_TRIM_SPACES=true

# ============================================================
# Cache
# ============================================================
REBUILD_CACHE=false
CACHE_KEY_MODE=file_name
DOCS_CACHE_DIR=docs/cache

# ============================================================
# Preprocessing
# ============================================================
USE_LLM_ATOMIZATION=true
USE_LLM_FIELD_EXTRACTION=true
NORMALIZE_LANGUAGE_FOR_KEYWORD_MATCHING=false
USE_LLM_KEYWORD_NORMALIZATION=false
PIVOT_LANGUAGE=en

# ============================================================
# Matching heuristic
# ============================================================
BIDIRECTIONAL_MAPPING=false
USE_SEMANTIC_MATCHING=true
USE_KEYWORD_MATCHING=false
USE_STRUCTURED_FIELD_MATCHING=true
USE_RRF=true
TOP_K_CANDIDATES=20
# Only the best LLM_TOP_K_CANDIDATES are sent to the pairwise judge. Retrieval can stay broad while prompts stay small.
LLM_TOP_K_CANDIDATES=20
RRF_K=60

# In soft_enisa mode, category is a positive prior only. It never removes a candidate.
WEIGHT_SEMANTIC=0.35
WEIGHT_KEYWORD=0.00
WEIGHT_STRUCTURED=0.30
WEIGHT_ACTION_OBJECT=0.30
WEIGHT_CONTROL_TYPE=0.05
WEIGHT_CATEGORY_PRIOR=0.03
MIN_CANDIDATE_COMBINED_SCORE=0.04
ENABLE_GLOBAL_FALLBACK=true
GLOBAL_FALLBACK_TOP_K=3

# Object/action gate caps over-optimistic coverage; it does not force Gap.
ENFORCE_OBJECT_ACTION_GATE=true
OBJECT_ACTION_GATE_MODE=score_cap
OBJECT_ACTION_HIGH_COVERAGE_THRESHOLD=0.75
OBJECT_ACTION_CAP_75_THRESHOLD=0.25
OBJECT_ACTION_CAP_25_THRESHOLD=0.10

USE_LLM_PAIRWISE_EVALUATION=true
# LLM_SELF_REVIEW injects {self_review_rounds} into the prompt — not wired yet in PROMPT_PAIRWISE_MATCH.
# LLM_REPEAT_ON_LOW_CONFIDENCE=true already handles re-evaluation of uncertain decisions.
LLM_SELF_REVIEW=false
LLM_SELF_REVIEW_ROUNDS=0
LLM_REPEAT_ON_LOW_CONFIDENCE=true
LLM_CONFIDENCE_THRESHOLD=0.65

# Parallel pairwise LLM calls. If Azure rate limits, lower to 2 or 1.
MAX_CONCURRENT_LLM_CALLS=9

# Cache expensive pairwise LLM decisions across reruns.
ENABLE_MAPPING_DECISION_CACHE=true
MAPPING_DECISION_CACHE_FILE=mapping_decisions_cache.jsonl

# Safe shortcut for obvious non-matches, before LLM. Keep thresholds conservative.
ENABLE_OBVIOUS_GAP_SHORTCUT=true
OBVIOUS_GAP_COMBINED_THRESHOLD=0.10
OBVIOUS_GAP_SEMANTIC_THRESHOLD=0.20
OBVIOUS_GAP_ACTION_OBJECT_THRESHOLD=0.15

# Candidate rescue prevents over-strict LLM/gate decisions from becoming false true gaps.
ENABLE_CANDIDATE_RESCUE=true
CANDIDATE_RESCUE_PARTIAL_COMBINED_THRESHOLD=0.55
CANDIDATE_RESCUE_PARTIAL_SEMANTIC_THRESHOLD=0.60
CANDIDATE_RESCUE_IMPLEMENTATION_COMBINED_THRESHOLD=0.55
CANDIDATE_RESCUE_INDIRECT_COMBINED_THRESHOLD=0.55
CANDIDATE_RESCUE_INDIRECT_SEMANTIC_THRESHOLD=0.70

RUN_FINAL_LLM_JUDGE=true
FINAL_JUDGE_ONLY_AMBIGUOUS=false
FINAL_JUDGE_CONFIDENCE_THRESHOLD=0.80
FINAL_JUDGE_BATCH_SIZE=25

# ============================================================
# Output
# ============================================================
USE_OUTPUT_TEMPLATE=false
OUTPUT_TEMPLATE_PATH=templates/Professional mapping template.xlsx
OUTPUT_DIR=output
LOG_DIR=logs
REPORT_DIR=reports
OUTPUT_FILENAME_PATTERN=mapping_{framework_a}_{framework_b}_{date}_{time}.xlsx
OUTPUT_MAIN_VIEW=parent
INCLUDE_ATOMIC_DETAIL_SHEETS=true
OUTPUT_LANGUAGE=en
ORGANIZATION_NAME=

# ============================================================
# Prompts
# Keep prompts on one line. Use \n for line breaks.
# ============================================================
PROMPT_CATEGORY_HARMONIZATION="You are a strict ENISA/NIS2 taxonomy classifier. Classify the requirement into the provided taxonomy only. The original category may be wrong. Categories are used as advisory retrieval signals, so accuracy and secondary categories matter. Choose the category based on the main obligation: actor, action, object, scope and evidence. Do not choose Incident handling merely because the word monitor appears; monitoring remote access/accounts is Access control. Do not choose Training when the obligation is accounts, authentication, access rights or privileges. If cryptographic mechanisms/encryption/key management are required, choose or include Cryptography. If routine maintenance, patching, vulnerability, configuration, network architecture or MCO/MCS are the main object, choose category 6. Return JSON only with keys: primary_category, secondary_categories, confidence, reason, status. primary_category and secondary_categories must exactly match provided categories. status must be validated, medium_confidence, low_confidence or multi_domain.\n\nFramework: {framework}\nControl ID: {control_id}\nTitle: {title}\nOriginal category: {original_category}\nRequirement: {requirement}\nStructured fields JSON: {fields}\nKeywords JSON: {keywords}\nDeterministic candidates JSON: {deterministic_candidates}\nENISA category cards JSON: {enisa_categories}"

PROMPT_ATOMIZE="You are a regulatory requirement atomization expert.\n\nSplit the requirement into atomic obligations. A valid atomic obligation contains one main actor, one mandatory action, one main object and one verifiable obligation. Split when there are multiple actions, objects, recipients, deadlines, conditions or evidence expectations. Each atom must be self-contained.\n\nReturn JSON only with one top-level key named atomic_requirements. atomic_requirements must be a list of objects with keys: text, action, object, reason.\n\nFramework: {framework_name}\nControl ID: {control_id}\nTitle: {title}\nENISA category: {category}\nRequirement: {requirement}"

PROMPT_EXTRACT_FIELDS="You are a regulatory control analyst. Extract structured fields from the atomic requirement. Return JSON only with these keys: domain, actor, action, object, condition, deadline, evidence, obligation_type, control_type, keywords.\n\nRules: action must be the main mandatory verb. object must be the exact controlled object. control_type must classify the obligation, for example access_control, awareness_training, logging_monitoring, incident_response, asset_inventory, cryptography, backup_continuity, supply_chain, governance, physical_security. keywords must be short discriminant terms in the pivot language when possible.\n\nENISA category: {category}\nAtomic requirement: {atomic_requirement}"

PROMPT_KEYWORD_NORMALIZATION="You are a regulatory translation and terminology normalization expert. Produce a stable keyword-matching representation in the pivot language without changing meaning or adding obligations.\n\nReturn JSON only with: keyword_text:string, keywords:list[string].\n\nPivot language: {pivot_language}\nCategory: {category}\nAtomic requirement: {atomic_requirement}\nStructured fields: {fields}\nCurrent keywords: {keywords}"

PROMPT_PAIRWISE_MATCH="You are a regulatory coverage mapping judge. Your task is to classify how much the target framework covers the source obligation, not to require perfect wording equivalence.\n\nLanguage note: Source and target requirements may be written in different languages (e.g., English and French). Always compare meaning, regulatory intent and security objective — never penalize coverage because of language differences or different legal drafting styles.\n\nCompare one source atomic requirement against target candidates. Candidates are retrieval suggestions only; semantic similarity is not proof, but a materially related candidate should not be discarded as a true gap.\n\nCategory policy: ENISA categories are advisory signals only. They may be wrong. Do not reject or accept based on category alone.\n\nMANDATORY PRE-SCORING STEP — OBLIGATION DECOMPOSITION: Before assigning any score, decompose the SOURCE obligation and record it in the output fields key_action, key_object, key_condition.\n- key_action: the specific mandatory action, KEEPING its discriminating qualifiers (e.g. 'automated notification' not just 'notification'; 'predefined severity-proportionate response' not just 'response'; 'kept separate/segregated' not just 'backed up').\n- key_object: what the action applies to, WITH its scope (e.g. 'all critical assets at rest' not just 'assets'; 'critical system backups as distinct from critical data backups'; 'software/firmware integrity' not just 'security').\n- key_condition: the triggering condition or constraint that defines the obligation, if any (e.g. 'upon discovering an integrity discrepancy'; 'through coordination with all BC/IR functions'; 'proportionate to severity'); write 'none' when the obligation has no defining condition.\nThen judge EACH target by asking: does the target satisfy key_action on key_object under key_condition — through EQUIVALENT concepts, not necessarily the same words? Score proportionally to which elements are truly satisfied:\n- all three satisfied through equivalent concepts (even with entirely different wording or legal drafting) → 80-100; different wording must NEVER lower this.\n- key_action satisfied but key_object or key_condition differs materially → 40-70, proportional to how much is missing (fewer missing = higher).\n- key_object scope is a strict SUBSET of what the source requires → cap at 40 (see SCOPE LIMITATION RULE).\n- target addresses a genuinely different functional domain / security objective → true_gap, 0.\nThe decomposition tells you WHICH element is decisive: for some obligations the action qualifier is what matters, for others the object scope, for others the triggering condition. Focus judgment on the element that would make the obligation UNSATISFIED if it were absent or different — and do NOT penalize peripheral wording that does not change whether the obligation is met. This step guards symmetrically against BOTH false positives (crediting a different obligation for shared vocabulary) and false gaps (denying coverage because the words differ). Record your domain determination in the output field same_functional_domain: true when the target genuinely addresses the source's key obligation domain, false when it shares only the same broad theme or is a genuinely different functional obligation. Set it false ONLY after deliberate decomposition-based analysis — a false value asserts a definitive true gap and instructs the system not to second-guess it using retrieval similarity.\n\nRelation taxonomy to use:\n- direct_full_coverage / 100: target fully covers actor, action, object, scope, condition, evidence and granularity. No residual gap.\n- mostly_covered / 80 or 90: target covers the same obligation with minor residual differences. Use 90 when only minor implementation/procedure/evidence gaps remain. Use 80 when meaningful implementation detail or scope gaps exist but the obligation is the same.\n- partial / 40 to 70: target covers the same functional domain but material elements remain missing. Use 70 for 1-2 missing material elements, 60 for several missing, 50 for many missing, 40 when only the objective broadly matches.\n- implementation_detail_gap / 70 or 80: target covers the high-level obligation but lacks implementation detail, explicitness, evidence, frequency, condition, procedure or operational granularity. Use 80 when gap is minor, 70 when gap is moderate.\n- indirect_support / 10 to 30: target addresses a DIFFERENT functional domain or control type and only tangentially supports the source. Use 30 for clearly supportive, 20 for mainly enabling, 10 for minimal/tangential link only.\n- true_gap / 0: no target candidate provides meaningful regulatory or operational coverage. Use this only as a last resort.\n- conflict / 0: target contradicts the source obligation.\n\nPRECEDENCE RULE (resolves any apparent conflict among the rules that follow): the OBLIGATION DECOMPOSITION and the TRUE GAP RULE GOVERN — apply them first. 'Same functional domain' means the target satisfies the source's key_action on its key_object, NOT merely the same broad theme. Same theme but different obligation is a TRUE GAP, never a high baseline: e.g. automated integrity-violation response vs general incident response (both 'incident handling'); backup segregation of systems-vs-data vs general backup procedures (both 'backups'); DoS protection of critical systems vs crisis/incident management (both 'resilience'). Do NOT start from a baseline of 80 for a mere thematic match. Only once the target genuinely addresses the source's key obligation do you score it: 80-100 when key_object and key_condition also match, 40-70 when they differ materially.\nCRITICAL DISTINCTION — partial_gap vs indirect_support_gap:\nUse partial_gap (40 to 70) when source and target address the SAME functional obligation or control domain, even if wording, scope, or explicitness differs. Examples: both address risk management, both address access controls, both address logging/monitoring, both address incident response, both address business continuity, both address supply chain oversight.\nUse indirect_support_gap (10 to 30) ONLY when the target imposes a GENUINELY DIFFERENT functional obligation that merely enables or supports the source (e.g., source requires incident response procedures; target only mandates security awareness training).\nWhen uncertain between partial and indirect: choose partial_gap (50 as default), UNLESS the OBLIGATION DECOMPOSITION shows the target addresses a different key obligation (same theme only) — that is a TRUE GAP per the PRECEDENCE and TRUE GAP rules, not partial. Never downgrade to indirect merely because the target is less explicit, more abstract, or shorter — use implementation_detail_gap (70 or 80) instead.\nA target that imposes the same type of obligation with fewer conditions or less granularity is partial_gap, not indirect_support_gap.\n\nGap classification: return gap_type as one of none, true_gap, partial_gap, implementation_detail_gap, indirect_support_gap, conflict_gap. Do not use true_gap when a candidate provides meaningful partial, implementation-level or indirect coverage.\n\nComposite coverage: you may select up to 2 target candidates when the source is covered by a combination of target provisions; only combine targets that each cover a distinct material element of the source — do not add a target that merely shares vocabulary. Set match_type to Composite and explain combine_controls.\n\nObject/action policy: Exact requires same main action and main object. Weak action/object alignment should cap coverage, not force true_gap. Use 50 for same objective with missing action/object detail, 30 for supportive-only relation. If source is access control / privileged account / authentication and target is only training or awareness, maximum coverage is 30.\n\nPRIORITY RULE (applies ONLY after the OBLIGATION DECOMPOSITION confirms the target satisfies the source's key_action on its key_object; never use it to lift a same-theme-but-different-obligation match — that is a true gap): If the target addresses the same obligation and the same security objective as the source, assign 90-100 even when wording, legal drafting style, or minor implementation details differ. Only deduct below 80 when a MATERIAL element (actor, action, object, or scope) is verifiably ABSENT from the target. Never cap coverage merely because the main object is phrased differently (e.g., \"mission\" vs \"governance policy\") when the underlying obligation is addressed. EQUIVALENCE RULE: A target that establishes, approves or maintains a formal security policy (PSSI), framework or governance structure inherently satisfies source obligations to establish, communicate, document or set the basis for governance, mission, strategy or risk-management. Credit this as high coverage (80-100), not partial: the policy is the vehicle that carries these obligations even if the exact words mission or communicate do not appear in the target. TRUE GAP RULE: If the only available targets address a DIFFERENT functional domain or security objective than the source, assign true_gap with coverage 0. Do NOT award 20-50 partial credit merely for sharing cybersecurity vocabulary or the same broad theme. Tangential domain overlap is a true gap, not indirect coverage. Confirmed true-gap pairs (use these as calibration anchors): (a) source = software/firmware/information integrity checking or integrity verification → target = network segmentation or general incident response → true gap; (b) source = automated responses to integrity violations with predefined severity-proportionate safeguards → target = general incident response mechanisms (INCIDENT.d) or ANSSI hardening guides → true gap; (c) source = anti-DoS or availability protection for critical systems → target = crisis management or general incident response → true gap; (d) source = backup segregation: critical system backups kept separate from critical data backups → target = general backup procedures (any framework) → true gap; (e) source = cross-functional coordinated backup testing integrated into BC/DR/IR resilience planning → target = annual backup and restoration testing process alone → true gap. SCOPE LIMITATION RULE: If a target requirement explicitly restricts its own scope to a SUBSET of what the source requires (e.g. target covers only mass storage of remote-access workstations from non-controlled locations but source covers all critical assets at rest; or target covers only rewritable removable media necessary for operations but source mandates full portable storage media policy including data-leakage and unauthorized-access safeguards), coverage from that target CANNOT exceed 40% even if the obligation type partially matches. Always state the scope limitation explicitly in the justification and in a gap_item with dimension=scope and severity=material.\n\nCALIBRATION EXAMPLES (apply the OBLIGATION DECOMPOSITION, then score — note the two failure modes are corrected in BOTH directions):\n- Example 1 — same obligation, different words → HIGH coverage: Source 'ensure availability and integrity of systems through regular backup testing'; Target 'verify backups can be restored after a disaster, tested annually'. key_action=backup testing, key_object=systems, key_condition=regular/periodic → target satisfies all three via equivalent concepts → coverage 80. Different wording and drafting style must NOT lower this; do NOT downgrade to indirect just because the words differ.\n- Example 2 — same broad domain, DIFFERENT obligation → TRUE GAP: Source 'define and implement automated responses to integrity violations using predefined severity-proportionate safeguards'; Target 'implement organizational and technical mechanisms to respond to incidents and limit service disruption'. key_action=automated + predefined proportionate response, key_object=integrity violations specifically, key_condition=proportionate to severity → target covers GENERAL incident response, not integrity-violation-specific automated response → true_gap, coverage 0. Shared 'response' vocabulary is not coverage.\n- Example 3 — obligation partially present → PARTIAL credit with scope gap: Source 'protect the confidentiality of all critical assets at rest'; Target 'encrypt the mass storage of workstations used for remote access from non-controlled locations'. key_action=confidentiality protection (present via encryption), key_object=all critical assets at rest (target covers only a strict subset: remote-access workstations) → coverage 35 with a material dimension=scope gap_item naming the excluded assets.\n\nCoverage scoring rules — use only multiples of 10 between 0 and 100:\n- 100: full direct coverage, no residual gap.\n- 90: mostly covered, only minor implementation/evidence/procedure gaps remain.\n- 80: mostly covered, meaningful implementation detail or scope gaps but same obligation.\n- 70: largely covered, 1-2 material elements (actor/action/object/scope) missing.\n- 60: well covered, several material elements missing but same functional domain.\n- 50: partially covered, many material elements missing, same objective.\n- 40: weakly covered, covers the objective broadly but key actor/action/object differ materially.\n- 30: indirect support, different functional domain but clearly supportive.\n- 20: very indirect, mainly enabling or supporting from a different domain.\n- 10: minimal link, only tangential connection exists.\n- 0: true_gap or conflict only.\n\nGap quality rules: for coverage below 100, produce precise residual gaps. Do not repeat the full source requirement. Do not use generic wording such as not fully covered without explaining the missing actor/action/object/scope/condition/deadline/evidence/governance/explicitness/control_type element.\n\nReturn gap_items as a list. Each entry must include: dimension, gap, target_coverage, severity. dimension must be one of actor, action, object, scope, condition, deadline, evidence, governance, explicitness, control_type. severity must be minor, moderate or material. For implementation_detail_gap, focus on missing procedure, evidence, explicitness, frequency, operational detail or granularity.\n\nb_contribution: if a candidate is selected, write 1-2 sentences on what the BEST selected target requirement addresses or specifies that the source does NOT already state — positive additions from target to source only. Empty string if the target adds nothing new to the source obligation, or if no candidate is selected.\n\nReturn JSON only with keys: key_action, key_object, key_condition, same_functional_domain, selected_candidate_ids, relation_type, gap_type, equivalence_level, coverage_level, match_type, confidence, dimension_scores, gap_dimensions, gap_items, justification, gap, combine_controls, recommendation, mapping_risk, scoring_rationale, b_contribution. key_action, key_object and key_condition are the SOURCE obligation decomposition from the mandatory pre-scoring step and must always be filled (short phrases, in {output_language}). same_functional_domain must be a boolean (true or false) reflecting the decomposition domain determination.\n\ndimension_scores must contain actor, action, object, scope, condition, deadline, evidence, control_type, granularity with values full, partial, missing, not_applicable. Write justification, gap, gap_items, recommendation and b_contribution in {output_language}.\n\nSource requirement JSON: {source_requirement}\n\nCandidate target requirements JSON: {candidates_json}"

PROMPT_FINAL_JUDGE="You are a senior regulatory parent-aware mapping reviewer. Make a DECISIVE, correct coverage judgment for each source requirement, correcting both false positives (over-credited) and false true-gaps (under-credited). ENISA categories are advisory only and may be wrong.\n\nCategory: {category}\nWrite all text fields (justification, gap, gap_items, recommendation) in {output_language}.\n\nApply this framework IN ORDER for each item:\n1. KEY OBLIGATION — identify the source's core actor+action+object. Judge coverage on whether THAT is satisfied, not on whether every peripheral word matches.\n2. SAME DOMAIN? — if targets address a genuinely DIFFERENT functional domain, assign true_gap, coverage 0. Shared cybersecurity vocabulary is NOT coverage. Confirmed true-gap pairs (calibration anchors): integrity checking vs network segmentation; integrity checking vs general incident response; automated integrity-violation response vs general incident response; DoS/availability protection vs crisis or incident management; backup segregation (systems vs data) vs general backup procedures; cross-functional coordinated backup testing vs annual backup testing alone. SCOPE LIMITATION: if the target's own text explicitly restricts its scope to a subset (e.g. 'mass storage of remote-access workstations' but source covers all critical assets at rest; 'rewritable removable media for operations' but source covers all portable storage media with full policy), coverage CANNOT exceed 40% — flag as a material scope gap_item.\n3. EQUIVALENCE — a target that establishes/approves/maintains a formal policy (PSSI) or governance framework inherently satisfies obligations to establish, communicate, document or set the basis for governance, mission, strategy or risk-management, even if the words mission or communicate never appear. Credit as high coverage (80-100).\n4. DECISIVE SCORING — if the key obligation is substantively covered, assign 90-100 even when wording or minor details differ. Deduct to 60-80 only when a MATERIAL element (actor/action/object/scope) is verifiably missing. Deduct to 40-50 only when several material elements are missing but the same domain applies. NEVER default to 50.\n\nCoverage scale (multiples of 10 only): 100=substantively complete, 80-90=mostly covered, 40-70=partial same-domain, 10-30=indirect (different domain but genuinely supportive), 0=true gap or conflict.\n\nGap type rules:\n- none: full coverage (100).\n- true_gap: no meaningful coverage — only when step 2 confirms different functional domain.\n- partial_gap (40-70): same domain, material elements missing.\n- implementation_detail_gap (70-80): same obligation, missing procedure/evidence/granularity.\n- indirect_support_gap (10-30): genuinely different domain but supportive.\n- conflict_gap: target contradicts source.\n\nWhen correcting coverage, also correct gap_type and gap_items. gap_items must use: dimension (actor/action/object/scope/condition/deadline/evidence/governance/explicitness/control_type), gap, target_coverage, severity (minor/moderate/material).\n\nReturn JSON only with two top-level keys: summary and corrections. corrections is a list — only include items you change. Each correction may include: source_id, selected_candidate_ids, relation_type, gap_type, equivalence_level, coverage_level, match_type, justification, gap, gap_items, combine_controls, recommendation, confidence, mapping_risk, scoring_rationale.\n\nMapping results JSON: {mapping_results_json}"
# ============================================================
# Parent gap LLM synthesis
# ============================================================
# Optional premium step: one LLM synthesis per parent requirement to produce the parent Gap column.
# This improves the business value of the parent sheet but adds extra LLM calls.
ENABLE_PARENT_GAP_LLM_SYNTHESIS=true
PARENT_GAP_SYNTHESIS_ONLY_FOR_NON_FULL_COVERAGE=true
PARENT_GAP_SYNTHESIS_MAX_CONCURRENT_CALLS=3
PARENT_GAP_SYNTHESIS_MAX_TEXT_CHARS=1000
ENABLE_PARENT_GAP_SYNTHESIS_CACHE=true
PARENT_GAP_SYNTHESIS_CACHE_FILE=parent_gap_synthesis_cache.jsonl

PROMPT_PARENT_GAP_SYNTHESIS="You are a senior regulatory reviewer synthesizing parent-level mapping gaps. This step is the parent final judge for the Gap column.\n\nGoal: produce a concise but complete residual gap analysis for the parent source requirement, based on selected target parent requirements and atomic decisions.\n\nRules:\n1. Do not mention atoms, embeddings, scores, prompts, gates, candidates, LLM, or technical internals.\n2. Do not repeat the full source requirement.\n3. Decide the parent_gap_type: none, true_gap, partial_gap, implementation_detail_gap, indirect_support_gap, conflict_gap.\n4. true_gap means no meaningful target coverage remains. Do not use true_gap when partial, implementation-level or indirect coverage exists.\n5. partial_gap means material actor/action/object/scope/condition/evidence elements remain missing despite partial coverage.\n6. implementation_detail_gap means high-level coverage exists but implementation detail, evidence, frequency, procedure, explicitness or operational granularity is missing.\n7. indirect_support_gap means the target supports the objective but does not impose the same direct obligation.\n8. Merge duplicates, but keep every materially distinct gap; do not artificially limit bullets.\n9. Group each gap by dimension: actor, action, object, scope, condition, deadline, evidence, governance, explicitness.\n10. Write in {output_language}.\n\nReturn JSON only:\n{\n  \"parent_relation_type\": \"direct_full_coverage|mostly_covered|partial|implementation_detail_gap|indirect_support|true_gap|conflict\",\n  \"parent_gap_type\": \"none|true_gap|partial_gap|implementation_detail_gap|indirect_support_gap|conflict_gap\",\n  \"coverage_synthesis\": \"One concise sentence summarizing coverage.\",\n  \"residual_gaps\": [\n    {\n      \"dimension\": \"actor|action|object|scope|condition|deadline|evidence|governance|explicitness\",\n      \"gap\": \"Concise but specific residual gap.\",\n      \"severity\": \"minor|moderate|material\"\n    }\n  ],\n  \"overall_impact\": \"One concise sentence explaining practical implication.\"\n}\n\nSource parent ID:\n{source_parent_id}\n\nSource parent requirement:\n{source_parent_requirement}\n\nTarget framework:\n{target_framework}\n\nSelected target parent requirements:\n{target_parent_requirements_json}\n\nAtomic coverage decisions and residual gap evidence:\n{atomic_decisions_json}"
# ============================================================
# Guideline RAG enrichment
# Place guideline files in data/guidelines/ named:
#   guidelines_{FRAMEWORK_NAME}.pdf  (or .txt / .md / .docx)
# The index is built once and cached automatically.
# ============================================================
USE_GUIDELINE_RAG=false
GUIDELINE_DIR=data/guidelines
GUIDELINE_TOP_K=3
GUIDELINE_CHUNK_SIZE=400
GUIDELINE_CHUNK_OVERLAP=80

STRONG_CANDIDATE_UPGRADE_ACTION_OBJECT_THRESHOLD=0.18
STRONG_CANDIDATE_UPGRADE_COMBINED_THRESHOLD=0.58
SCORE_FLOOR_SEMANTIC_THRESHOLD=0.80
STRONG_CANDIDATE_UPGRADE_STRUCTURED_THRESHOLD=0.10
STRONG_CANDIDATE_UPGRADE_SEMANTIC_THRESHOLD=0.76
STRONG_CANDIDATE_UPGRADE_EXACT_SEMANTIC_THRESHOLD=0.84
SCORE_FLOOR_COMBINED_THRESHOLD=0.60
SCORE_FLOOR_ENABLED=true
SCORE_FLOOR_ACTION_OBJECT_THRESHOLD=0.20
NOT_COVERED_COMBINED_THRESHOLD=0.35
NOT_COVERED_SEMANTIC_THRESHOLD=0.55
# Strict thresholds for coverage <= 20% (OR logic): both scores must exceed these to keep the label
NOT_COVERED_STRICT_COMBINED_THRESHOLD=0.45
NOT_COVERED_STRICT_SEMANTIC_THRESHOLD=0.65
STRONG_CANDIDATE_UPGRADE_EXACT_COMBINED_THRESHOLD=0.68

# ============================================================
# Consolidated framework generation
# Set RUN_CONSOLIDATED_FRAMEWORK=true to generate a merged framework Excel
# after the mapping. Requires the b_contribution field in the pairwise match
# LLM output (already included in PROMPT_PAIRWISE_MATCH above).
# For Pass 2 (B-only requirements), set BIDIRECTIONAL_MAPPING=true.
# ============================================================
RUN_CONSOLIDATED_FRAMEWORK=false
CONSOLIDATED_BATCH_SIZE=20
# B parent requirements with coverage_B->A below this threshold (%) are added
# as new requirements in Pass 2 (B-only). Set 0 to skip Pass 2 entirely.
CONSOLIDATED_ORPHAN_THRESHOLD=40

PROMPT_CONSOLIDATED_BATCH="You are a regulatory framework consolidation expert.\n\nFor each requirement below, write a single consolidated requirement that:\n1. Preserves ALL obligations from the source requirement A — do not omit any obligation\n2. Incorporates any additional obligations or precision from the best matching B requirement that A does not already state (see b_contribution field)\n3. Explicitly addresses the identified gap so the consolidated text is complete and self-sufficient\n4. Is written as a single coherent regulatory sentence or short paragraph, not a bullet list\n5. Does not repeat the same obligation twice when A and B address it identically\n\nThe consolidated requirement must be MORE complete than either A or B alone. When b_contribution is empty or coverage is already high, still verify the gap field and add any missing element.\n\nOutput language: write consolidated_text in {output_language}.\n\nReturn JSON only:\n{\"results\": [{\"id\": \"<id>\", \"consolidated_text\": \"<text>\"}]}\n\nItems to consolidate:\n{items_json}"

PROMPT_CONSOLIDATED_SUPPLEMENT="You are a regulatory framework consolidation expert.\n\nThe following requirements from Framework B are only partially covered by the existing consolidated framework (coverage below {orphan_threshold}%). For each item, determine whether it introduces a GENUINELY NEW regulatory obligation not yet captured in the consolidated framework.\n\nIf YES: write a new consolidated_text that covers the new obligation concisely.\nIf NO (the obligation is already implied or captured): set already_covered to true.\n\nOutput language: write consolidated_text in {output_language}.\n\nReturn JSON only:\n{\"results\": [{\"id\": \"<id>\", \"consolidated_text\": \"<text or null>\", \"already_covered\": false}]}\n\nItems:\n{items_json}"
